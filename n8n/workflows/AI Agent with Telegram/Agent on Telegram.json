    {
      "parameters": {
        "jsCode": "function escapeHtml(text) {\n  return text\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;');\n}\n\nfunction cleanLatex(text) {\n  return text\n    // usuń $...$\n    .replace(/\\$(.*?)\\$/g, '$1')\n\n    // latex multiplication\n    .replace(/\\\\times/g, '×');\n}\n\nfunction markdownToTelegramHtml(text) {\n  if (!text) return text;\n\n  let cleaned = cleanLatex(text);\n  let escaped = escapeHtml(cleaned);\n\n  escaped = escaped\n    // bold **text**\n    .replace(/\\*\\*(.*?)\\*\\*/g, '<b>$1</b>')\n\n    // italic *text*\n    .replace(/\\*(.*?)\\*/g, '<i>$1</i>')\n\n    // code `text`\n    .replace(/`(.*?)`/g, '<code>$1</code>');\n\n  return escaped;\n}\n\nfor (const item of $input.all()) {\n  const text = item.json.output;\n  item.json.html = markdownToTelegramHtml(text);\n}\n\nreturn $input.all();"
      },
