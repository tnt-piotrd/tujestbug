        "documentURL": "={{ $json.id }}",
        "actionsUi": {
          "actionFields": [
            {
              "action": "insert",
              "text": "=Title: Reset failed login attempts after successful authentication\n\nDescription:\n As a registered user,\n I want my failed login attempts to be reset after a successful login,\n so that occasional mistakes do not lead to unnecessary account lockout.\n\nDetails:\n Once a user successfully authenticates, any previously recorded failed login attempts should be cleared.\nThis ensures that only consecutive failed attempts contribute to potential account lockout and improves overall user experience."
            }
          ]
        }
